---
import { contactLinks, navItems, t } from "../data/site";

const activeContactLinks = contactLinks.filter((link) => link.enabled && link.href);
---

<footer class="footer ref-demo-footer site-ref-footer" aria-label="Site footer">
  <div class="ref-demo-footer-top">
    <nav aria-label="Footer sections">
      <span>Site</span>
      {navItems.map((item) => (
        <a href={item.href}>
          <span aria-hidden="true">[→]</span>
          <strong data-i18n={item.key}>{t(item.key)}</strong>
        </a>
      ))}
    </nav>

    <nav aria-label={t("footer.contact")}>
      <span data-i18n="footer.contact">{t("footer.contact")}</span>
      {activeContactLinks.map((link) => (
        <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noreferrer" : undefined}>
          <span aria-hidden="true">[→]</span>
          <strong>{link.label}</strong>
        </a>
      ))}
    </nav>

    <address>
      <span>A</span>
      <strong>Peking University<br />Yuanpei College</strong>
      <span>E</span>
      <a href="mailto:shuangbenchen25@stu.pku.edu.cn">shuangbenchen25@stu.pku.edu.cn</a>
    </address>
  </div>

  <div class="ref-demo-footer-bottom">
    <a class="ref-demo-footer-logo" href="/" aria-label="Shuangben Chen homepage">
        <span>2Ben</span>
        <strong>Shuangben Chen</strong>
    </a>
  </div>
</footer>
