---
import { navItems, t } from "../data/site";
---

<header class="topbar">
  <div class="ref-demo-header site-ref-header" aria-label="Site header">
    <div class="ref-demo-header-grid nav">
    <a class="ref-demo-logo" href="/" aria-label="Shuangben Chen homepage">
      <span class="ref-demo-logo-mark">2Ben</span>
      <span class="ref-demo-logo-name">Shuangben<br />Chen</span>
    </a>

    <div class="ref-demo-header-content nav-links site-ref-header-content">
      <nav class="ref-demo-nav" aria-label="Primary navigation">
        {navItems.map((item) => (
          <a class="ref-demo-bracket-link" href={item.href}>
            <span aria-hidden="true">[</span>
            <em data-i18n={item.key}>{t(item.key)}</em>
            <span aria-hidden="true">]</span>
          </a>
        ))}
      </nav>

      <div class="ref-demo-actions nav-tools">
        <div class="ref-demo-search search">
          <input id="site-search" type="search" autocomplete="off" data-i18n-placeholder="search.placeholder" placeholder={t("search.placeholder")} aria-label={t("search.placeholder")}>
          <div id="search-results" class="search-results ref-demo-search-results" aria-live="polite"></div>
        </div>
      </div>
    </div>

    <button class="ref-demo-mobile-menu menu-toggle" id="menu-toggle" type="button" aria-expanded="false" aria-label="Menu">
      <span>Menu</span>
      <span aria-hidden="true">[=]</span>
    </button>
    </div>
  </div>

  <button class="ref-demo-dock-toggle site-ref-dock-toggle" type="button" data-site-dock-toggle aria-expanded="false">
    <span>Menu</span>
    <span aria-hidden="true">[=]</span>
  </button>

  <aside class="ref-demo-dock site-ref-dock" aria-label="Site quick index">
    <nav aria-label="Floating navigation">
      {navItems.map((item) => (
        <a class="ref-demo-bracket-link" href={item.href}>
          <span aria-hidden="true">[</span>
          <em data-i18n={item.key}>{t(item.key)}</em>
          <span aria-hidden="true">]</span>
        </a>
      ))}
    </nav>
    <div class="ref-demo-actions">
      <div class="ref-demo-search search">
        <input type="search" autocomplete="off" data-site-search data-i18n-placeholder="search.placeholder" placeholder={t("search.placeholder")} aria-label={t("search.placeholder")} />
        <div class="search-results ref-demo-search-results" data-search-results aria-live="polite"></div>
      </div>
    </div>
  </aside>
</header>
