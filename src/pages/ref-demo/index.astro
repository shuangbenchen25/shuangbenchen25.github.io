---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { contactLinks, homeSections, t } from "../../data/site";
import { collectContentPreviews } from "../../utils/content";

const blogModules = import.meta.glob("../../content/blog/**/*.md", { eager: true });
const blogRawModules = import.meta.glob("../../content/blog/**/*.md", { eager: true, query: "?raw", import: "default" });
const newsModules = import.meta.glob("../../content/news/**/*.md", { eager: true });
const newsRawModules = import.meta.glob("../../content/news/**/*.md", { eager: true, query: "?raw", import: "default" });

const sectionId = (href: string) => `demo-${href.replaceAll("/", "").replaceAll("-", "") || "about"}`;
const heroRefs = homeSections.slice(0, 3);
const enabledContacts = contactLinks.filter((link) => link.enabled);
const recentBlogPosts = collectContentPreviews(blogModules, blogRawModules, {
  basePath: "../../content/blog/",
  hrefForSlug: (slug) => `/blog/posts/${slug}/`,
  excerptLength: 110
}).slice(0, 3);
const recentNewsItems = collectContentPreviews(newsModules, newsRawModules, {
  basePath: "../../content/news/",
  hrefForSlug: (slug) => `/news/#${slug}`,
  excerptLength: 110
}).slice(0, 3);

const formatDisplayDate = (date: Date) => {
  const day = date.getDate();
  const suffix = day % 10 === 1 && day !== 11 ? "st" : day % 10 === 2 && day !== 12 ? "nd" : day % 10 === 3 && day !== 13 ? "rd" : "th";
  return `${date.toLocaleString("en-US", { month: "short" })} ${day}${suffix}`;
};
const latestBlogDate = recentBlogPosts[0] ? formatDisplayDate(recentBlogPosts[0].date) : "Recent";
const blogTagCounts = recentBlogPosts
  .flatMap((post) => post.tags)
  .reduce<Map<string, number>>((counts, tag) => counts.set(tag, (counts.get(tag) || 0) + 1), new Map());
const maxBlogTagCount = Math.max(1, ...blogTagCounts.values());
const blogTagCloud = Array.from(blogTagCounts.entries())
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 12)
  .map(([tag, count]) => ({ tag, count, weight: 0.75 + (count / maxBlogTagCount) * 1.15 }));
---

<BaseLayout title="REF Style Demo | Shuangben Chen" description="A temporary REF-inspired layout demo for Shuangben Chen's personal site.">
  <main class="ref-demo" id="content">
    <header class="ref-demo-header" aria-label="REF demo header">
      <div class="ref-demo-header-grid">
        <a class="ref-demo-logo" href="/ref-demo/" aria-label="REF demo home">
          <span class="ref-demo-logo-mark">2Ben</span>
          <span class="ref-demo-logo-name">Shuangben<br />Chen</span>
        </a>

        <div class="ref-demo-header-content">
          <nav class="ref-demo-nav" aria-label="Demo navigation">
            {homeSections.map((section) => (
              <a class="ref-demo-bracket-link" href={`#${sectionId(section.href)}`}>
                <span aria-hidden="true">[</span>
                <em data-i18n={section.titleKey}>{t(section.titleKey)}</em>
                <span aria-hidden="true">]</span>
              </a>
            ))}
          </nav>

          <div class="ref-demo-actions">
            <div class="ref-demo-search search">
              <input type="search" autocomplete="off" data-site-search data-i18n-placeholder="search.placeholder" placeholder={t("search.placeholder")} aria-label={t("search.placeholder")} />
              <div class="search-results ref-demo-search-results" data-search-results aria-live="polite"></div>
            </div>
          </div>
        </div>

        <button class="ref-demo-mobile-menu" type="button" data-ref-demo-menu aria-label="Open demo menu" aria-expanded="false">
          <span>Menu</span>
          <span aria-hidden="true">[≡]</span>
        </button>
      </div>
    </header>

    <button class="ref-demo-dock-toggle" type="button" data-ref-demo-dock-toggle aria-expanded="false">
      <span>Menu</span>
      <span aria-hidden="true">[≡]</span>
    </button>

    <aside class="ref-demo-dock" aria-label="Demo quick index">
      <nav aria-label="Demo floating navigation">
        {homeSections.map((section) => (
          <a class="ref-demo-bracket-link" href={`#${sectionId(section.href)}`}>
            <span aria-hidden="true">[</span>
            <em data-i18n={section.titleKey}>{t(section.titleKey)}</em>
            <span aria-hidden="true">]</span>
          </a>
        ))}
      </nav>
      <div class="ref-demo-actions">
        <div class="ref-demo-search search">
          <input type="search" autocomplete="off" data-site-search data-i18n-placeholder="search.placeholder" placeholder={t("search.placeholder")} aria-label={t("search.placeholder")} />
          <div class="search-results ref-demo-search-results" data-search-results aria-live="polite"></div>
        </div>
      </div>
    </aside>

    <section class="ref-demo-cover-card" aria-labelledby="ref-demo-title">
      <div class="ref-demo-intro">
        <div class="ref-demo-grid">
          <p class="ref-demo-lede" data-i18n="hero.lede">{t("hero.lede")}</p>
          <h1 id="ref-demo-title">Shuangben Chen</h1>
        </div>
      </div>

      <div class="ref-demo-hero-panel" aria-label="Selected record">
        <div class="ref-demo-hero-grid">
          <h2>Academic homepage</h2>
          <p class="ref-demo-project-ref">
            <span>2B</span>
            <strong>PKU AI</strong>
          </p>

          <div class="ref-demo-media" aria-hidden="true">
            <div class="ref-demo-media-card ref-demo-media-card-main">
              <span>AI</span>
              <strong>academics / research / design</strong>
            </div>
            <div class="ref-demo-media-card ref-demo-media-card-alt">
              <span>MD</span>
              <strong>blog / news / records</strong>
            </div>
          </div>

          <div class="ref-demo-thumb-strip" aria-label="Demo references">
            {heroRefs.map((section, index) => (
              <a href={`#${sectionId(section.href)}`}>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <strong data-i18n={section.titleKey}>{t(section.titleKey)}</strong>
                <small data-i18n={section.summaryKey}>{t(section.summaryKey)}</small>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="ref-demo-section ref-demo-about" aria-labelledby="ref-demo-about-title">
      <div class="ref-demo-section-header">
        <h2 id="ref-demo-about-title">about</h2>
        <div>
          <p data-i18n="hero.note">{t("hero.note")}</p>
          <a class="ref-demo-button ref-demo-button-dark" href="#demo-academics">Explore sections</a>
        </div>
      </div>

      <div class="ref-demo-about-body">
        <div class="ref-demo-proof">
          <span>PKU</span>
          <strong>Undergradute at Yuanpei College</strong>
          <p data-i18n="home.overview.desc">{t("home.overview.desc")}</p>
        </div>
        <div class="ref-demo-proof">
          <span>AI</span>
          <strong>Major in Robotics & World Models</strong>
          <p data-i18n="home.blog.detail1">{t("home.blog.detail1")}</p>
        </div>
      </div>
    </section>

    {homeSections.map((section, index) => {
      const isBlog = section.href === "/blog/";
      const isNews = section.href === "/news/";
      return (
      <section class={`ref-demo-section ref-demo-feature-panel ref-demo-feature-${index + 1}`} id={sectionId(section.href)} aria-labelledby={`${sectionId(section.href)}-title`}>
        <div class="ref-demo-section-header">
          <h2 data-i18n={section.kickerKey}>{t(section.kickerKey)}</h2>
          <div>
            <p data-i18n={section.summaryKey}>{t(section.summaryKey)}</p>
            <a class="ref-demo-button ref-demo-button-dark" href={section.href} data-i18n="home.more">{t("home.more")}</a>
          </div>
        </div>

        <div class="ref-demo-feature-stage">
          {!isNews && <a class="ref-demo-feature-mark" href={isBlog && recentBlogPosts[0] ? recentBlogPosts[0].href : section.href}>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{isBlog ? latestBlogDate : section.metrics[0]?.value || t(section.titleKey).slice(0, 2)}</strong>
            <small>{isBlog ? "Recent update" : section.metrics[0] ? t(section.metrics[0].labelKey) : t(section.kickerKey)}</small>
          </a>}

          <article class="ref-demo-feature-copy">
            <h3 id={`${sectionId(section.href)}-title`} data-i18n={section.titleKey}>{t(section.titleKey)}</h3>
            <blockquote data-i18n={section.quoteKey}>{t(section.quoteKey)}</blockquote>
            {isBlog ? (
              <div class="ref-demo-feature-details ref-demo-recent-links">
                {recentBlogPosts.map((post, detailIndex) => (
                  <a href={post.href}>
                    <span>{String(detailIndex + 1).padStart(2, "0")}</span>
                    <strong>{post.title}</strong>
                    <small>{post.dateLabel}</small>
                  </a>
                ))}
              </div>
            ) : isNews ? (
              <div class="ref-demo-news-timeline">
                {recentNewsItems.map((item) => (
                  <a href={item.href}>
                    <time datetime={item.date.toISOString()}>{item.dateLabel}</time>
                    <strong>{item.title}</strong>
                    {item.description && <span>{item.description}</span>}
                  </a>
                ))}
              </div>
            ) : (
              <div class="ref-demo-feature-details">
                {section.detailKeys.map((key, detailIndex) => (
                  <p>
                    <span>{String(detailIndex + 1).padStart(2, "0")}</span>
                    <span data-i18n={key}>{t(key)}</span>
                  </p>
                ))}
              </div>
            )}
          </article>

          {!isNews && <div class={`ref-demo-feature-console${isBlog ? " ref-demo-tag-cloud" : ""}`} aria-label={`${t(section.titleKey)} signals`}>
            {isBlog ? (
              blogTagCloud.map((item) => (
                <a href={`/blog/tags/${item.tag.toLowerCase().replace(/&/g, "and").replace(/[^a-z0-9\u4e00-\u9fff]+/g, "-").replace(/^-+|-+$/g, "")}/`} style={`--weight: ${item.weight}`}>
                  <span>#{item.tag}</span>
                  <small>{item.count}</small>
                </a>
              ))
            ) : (
              <>
            {section.signals.map((signal) => (
              <div class="ref-demo-feature-signal" style={`--level: ${signal.level}%`}>
                <div>
                  <span data-i18n={signal.labelKey}>{t(signal.labelKey)}</span>
                  <strong>{signal.value}</strong>
                </div>
                <i aria-hidden="true"></i>
              </div>
            ))}
            <ul>
              {section.pointKeys.map((key) => <li data-i18n={key}>{t(key)}</li>)}
            </ul>
              </>
            )}
          </div>}
        </div>
      </section>
      );
    })}

    <footer class="ref-demo-footer" aria-label="REF demo footer">
      <div class="ref-demo-footer-top">
        <nav aria-label="Demo footer sections">
          <span>Site</span>
          {homeSections.map((section) => (
            <a href={section.href}>
              <span aria-hidden="true">[→]</span>
              <strong data-i18n={section.titleKey}>{t(section.titleKey)}</strong>
            </a>
          ))}
        </nav>

        <nav aria-label="Demo footer contacts">
          <span>Contact</span>
          {enabledContacts.map((link) => (
            <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noreferrer" : undefined}>
              <span aria-hidden="true">[→]</span>
              <strong>{link.label}</strong>
            </a>
          ))}
        </nav>

        <address>
          <span>A</span>
          <strong>Peking University<br />Yuanpei College</strong>
          <span>E</span>
          <a href="mailto:shuangbenchen25@stu.pku.edu.cn">shuangbenchen25@stu.pku.edu.cn</a>
        </address>
      </div>

      <div class="ref-demo-footer-bottom">
        <a class="ref-demo-footer-logo" href="/ref-demo/" aria-label="REF demo home">
          <span>2Ben</span>
          <strong>Shuangben Chen</strong>
        </a>
      <nav aria-label="Demo legal links">
          <a href="/rss.xml">[ RSS ]</a>
          <a href="/sitemap.xml">[ Sitemap ]</a>
        </nav>
      </div>
    </footer>
  </main>
</BaseLayout>
