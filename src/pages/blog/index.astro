---
import PageHead from "../../components/PageHead.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../data/site";

const modules = import.meta.glob("../../content/blog/**/*.md", { eager: true });
const rawModules = import.meta.glob("../../content/blog/**/*.md", { eager: true, query: "?raw", import: "default" });

function slugFromPath(path: string) {
  return path
    .replace("../../content/blog/", "")
    .replace(/\.md$/, "")
    .split("/")
    .map((part) =>
      part
        .trim()
        .toLowerCase()
        .replace(/&/g, "and")
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "")
    )
    .filter(Boolean)
    .join("--");
}

function excerptFromMarkdown(raw: string, maxLength = 180) {
  const withoutFrontmatter = raw.replace(/^---[\s\S]*?---/, "");
  const text = withoutFrontmatter
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/\$\$[\s\S]*?\$\$/g, " ")
    .replace(/\$([^$]+)\$/g, "$1")
    .replace(/^#{1,6}\s+/gm, "")
    .replace(/^---+$/gm, " ")
    .replace(/!\[[^\]]*]\([^)]*\)/g, " ")
    .replace(/\[([^\]]+)]\([^)]*\)/g, "$1")
    .replace(/[*_~`>|-]/g, " ")
    .replace(/\s+/g, " ")
    .trim();

  if (text.length <= maxLength) {
    return text;
  }
  return `${text.slice(0, maxLength).trim()}...`;
}

const posts = Object.entries(modules)
  .map(([path, mod]) => {
    const post = mod as { frontmatter: { title: string; date: string | Date; description?: string } };
    const slug = slugFromPath(path);
    const date = new Date(post.frontmatter.date);
    const raw = String(rawModules[path] || "");
    return { ...post.frontmatter, slug, date, excerpt: excerptFromMarkdown(raw) };
  })
  .sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout title="Blog | Shuangben Chen" description="Blog and notes by Shuangben Chen.">
  <main class="site-shell">
    <PageHead titleKey="blog.title" descKey="blog.desc" title={t("blog.title")} desc={t("blog.desc")} />
    <section class="section">
      <div class="section-label"><h2 data-i18n="blog.title">{t("blog.title")}</h2><p data-i18n="blog.desc">{t("blog.desc")}</p></div>
      <article class="card">
        <div class="post-list">
          {posts.map((post) => (
            <a class="post-item" href={`/blog/posts/${post.slug}/`}>
              <span class="post-item-main">
                <strong>{post.title}</strong>
                {post.description && <span class="post-description">{post.description}</span>}
                {post.excerpt && <span class="post-excerpt">{post.excerpt}</span>}
              </span>
              <span class="post-date">{post.date.toISOString().slice(0, 10)}</span>
            </a>
          ))}
        </div>
      </article>
    </section>
  </main>
</BaseLayout>
