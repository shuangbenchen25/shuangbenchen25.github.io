---
import PageHead from "../../components/PageHead.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../data/site";

const modules = import.meta.glob("../../content/news/**/*.md", { eager: true });

const newsItems = Object.entries(modules)
  .map(([, mod]) => {
    const item = mod as {
      frontmatter: { title: string; date: string | Date; description?: string };
      Content: (_props: Record<string, never>) => unknown;
    };
    const date = new Date(item.frontmatter.date);
    return { ...item.frontmatter, date, Content: item.Content };
  })
  .sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout title="News | Shuangben Chen" description="Recent updates and notes by Shuangben Chen.">
  <main class="site-shell">
    <PageHead titleKey="news.title" descKey="news.desc" title={t("news.title")} desc={t("news.desc")} />
    <section class="section">
      <div class="section-label"><h2 data-i18n="news.title">{t("news.title")}</h2><p data-i18n="news.desc">{t("news.desc")}</p></div>
      <div class="news-list">
        {newsItems.map((item) => (
          <details class="news-item card">
            <summary>
              <span class="news-node" aria-hidden="true"></span>
              <span class="news-summary-main">
                <time class="date" datetime={item.date.toISOString()}>{item.date.toISOString().slice(0, 10)}</time>
                <strong>{item.title}</strong>
                {item.description && <span class="news-description">{item.description}</span>}
                <span class="news-read-more">Read more</span>
              </span>
            </summary>
            <div class="news-full markdown-body">
              <item.Content />
            </div>
          </details>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
