---
import PageHead from "../../components/PageHead.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../data/site";
import { getCollection } from "astro:content";
import { cvDateRange, groupCvEntries } from "../../utils/cv";

const cvEntries = await getCollection("cv");
const cvGroups = groupCvEntries(cvEntries);
const categoryLabels = {
  education: t("academics.education"),
  experience: t("academics.experience"),
  award: t("academics.awards"),
  skill: t("academics.skills")
};

const localeAttrs = (en?: string, zh?: string) => ({
  "data-locale-en": en || "",
  "data-locale-zh": zh || en || ""
});
---

<BaseLayout title="Academics | Shuangben Chen" description="Academics, education, awards, and skills of Shuangben Chen.">
  <main class="site-shell ref-site ref-subpage ref-academics">
    <PageHead code="AC" titleKey="academics.title" descKey="academics.desc" title={t("academics.title")} desc={t("academics.desc")} />
    <section class="section ref-stage">
      <div class="section-label">
        <span class="ref-code-label">// record ledger</span>
        <h2 data-i18n="academics.title">{t("academics.title")}</h2>
        <p data-i18n="academics.desc">{t("academics.desc")}</p>
      </div>
      <div class="content-grid ref-record-ledger">
        {cvGroups.map((group) => group.entries.length ? (
          <section class="academic-group" aria-labelledby={`academic-${group.category}`}>
            <div class="ref-record-strip">
              <span>{String(group.entries.length).padStart(2, "0")}</span>
              <strong id={`academic-${group.category}`}>{categoryLabels[group.category]}</strong>
              <small>{group.category}</small>
            </div>
            <div class="timeline">
              {group.entries.map((entry) => (
                <article class="timeline-item card">
                  <div class="date">{cvDateRange(entry)}</div>
                  <div>
                    <h4 {...localeAttrs(entry.data.title, entry.data.titleZh)}>{entry.data.title}</h4>
                    {entry.data.organization && (
                      <p
                        class="muted"
                        {...localeAttrs(
                          `${entry.data.organization}${entry.data.location ? ` · ${entry.data.location}` : ""}`,
                          `${entry.data.organizationZh || entry.data.organization}${entry.data.locationZh || entry.data.location ? ` · ${entry.data.locationZh || entry.data.location}` : ""}`
                        )}
                      >
                        {entry.data.organization}{entry.data.location ? ` · ${entry.data.location}` : ""}
                      </p>
                    )}
                    {entry.data.summary && <p {...localeAttrs(entry.data.summary, entry.data.summaryZh)}>{entry.data.summary}</p>}
                    {entry.data.highlights?.length ? (
                      <ul>
                        {entry.data.highlights.map((item, index) => <li {...localeAttrs(item, entry.data.highlightsZh?.[index])}>{item}</li>)}
                      </ul>
                    ) : null}
                    {entry.data.skills?.length ? (
                      <div class="tags">
                        {entry.data.skills.map((tag, index) => <span class="tag" {...localeAttrs(tag, entry.data.skillsZh?.[index])}>{tag}</span>)}
                      </div>
                    ) : null}
                  </div>
                </article>
              ))}
            </div>
          </section>
        ) : null)}
      </div>
    </section>
  </main>
</BaseLayout>
