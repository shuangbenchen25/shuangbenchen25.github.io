---
import PageHead from "../../../components/PageHead.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { t } from "../../../data/site";
import { getCollection } from "astro:content";
import { projectHref, projectsByTrack } from "../../../utils/projects";

const projects = projectsByTrack(await getCollection("projects"), ["design", "media"]);
---

<BaseLayout title="Design Portfolio | Shuangben Chen" description="Design portfolio by Shuangben Chen.">
  <main class="site-shell">
    <PageHead titleKey="projects.design.nav" descKey="projects.design.body" title={t("projects.design.nav")} desc={t("projects.design.body")} />
    <section class="section">
      <div class="section-label"><h2 data-i18n="projects.design.nav">{t("projects.design.nav")}</h2><p>Visual identity · Posters · Communication</p></div>
      <div class="content-grid">
        {projects.map((project) => (
          <a class="card project-card" href={projectHref(project)}>
            <p class="eyebrow">{project.data.type}</p>
            <h3>{project.data.title}</h3>
            <p class="muted">{project.data.description}</p>
            <div class="project-card-meta">
              <span>{project.data.status}</span>
              <span>{project.data.role}</span>
            </div>
            <div class="tags">{project.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
