---
import PageHead from "../../components/PageHead.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../data/site";
import { getCollection } from "astro:content";
import { projectHref, sortProjects } from "../../utils/projects";

const projects = sortProjects(await getCollection("projects"));
---

<BaseLayout title="Projects | Shuangben Chen" description="Projects and portfolio work of Shuangben Chen.">
  <main class="site-shell ref-site ref-subpage ref-projects">
    <PageHead code="PR" titleKey="projects.title" descKey="projects.desc" title={t("projects.title")} desc={t("projects.desc")} />
    <section class="section ref-stage">
      <div class="section-label">
        <span class="ref-code-label">// portfolio tracks</span>
        <h2 data-i18n="projects.title">{t("projects.title")}</h2>
        <p data-i18n="projects.desc">{t("projects.desc")}</p>
      </div>
      <div class="project-menu ref-project-board">
        {projects.map((project, index) => (
          <a class="card project-card ref-project-tile" href={projectHref(project)} style={`--tile-index: "${String(index + 1).padStart(2, "0")}"`}>
            <p class="eyebrow">{project.data.type}</p>
            <h3>{project.data.title}</h3>
            <p class="muted">{project.data.description}</p>
            <div class="project-card-meta">
              <span>{project.data.status}</span>
              <span>{project.data.role}</span>
            </div>
            <div class="tags">{project.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
