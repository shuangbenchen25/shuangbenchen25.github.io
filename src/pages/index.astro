---
import BaseLayout from "../layouts/BaseLayout.astro";
import { homeSections, t } from "../data/site";
import { collectContentPreviews } from "../utils/content";

const blogModules = import.meta.glob("../content/blog/**/*.md", { eager: true });
const blogRawModules = import.meta.glob("../content/blog/**/*.md", { eager: true, query: "?raw", import: "default" });
const newsModules = import.meta.glob("../content/news/**/*.md", { eager: true });
const newsRawModules = import.meta.glob("../content/news/**/*.md", { eager: true, query: "?raw", import: "default" });

const recentByHref = new Map([
  [
    "/blog/",
    collectContentPreviews(blogModules, blogRawModules, {
      basePath: "../content/blog/",
      hrefForSlug: (slug) => `/blog/posts/${slug}/`,
      excerptLength: 110
    }).slice(0, 3)
  ],
  [
    "/news/",
    collectContentPreviews(newsModules, newsRawModules, {
      basePath: "../content/news/",
      hrefForSlug: (slug) => `/news/#${slug}`,
      excerptLength: 110
    }).slice(0, 3)
  ]
]);

const overviewId = (href: string) => `overview-${href.replaceAll("/", "").replaceAll("-", "") || "about"}`;
---

<BaseLayout>
  <main class="site-shell">
    <section class="hero" aria-labelledby="intro-title">
      <div>
        <h1 id="intro-title">Shuangben Chen</h1>
        <p class="hero-lede" data-i18n="hero.lede">{t("hero.lede")}</p>
        <p class="hero-note" data-i18n="hero.note">{t("hero.note")}</p>
      </div>

      <aside class="profile-card" aria-label="Profile summary">
        <div class="portrait" aria-hidden="true">
          <div class="portrait-wordmark">2Ben</div>
        </div>
        <div class="profile-meta">
          <div class="meta-line"><span data-i18n="card.school.label">{t("card.school.label")}</span><strong data-i18n="card.school.value">{t("card.school.value")}</strong></div>
          <div class="meta-line"><span data-i18n="card.college.label">{t("card.college.label")}</span><strong data-i18n="card.college.value">{t("card.college.value")}</strong></div>
          <div class="meta-line"><span data-i18n="card.major.label">{t("card.major.label")}</span><strong data-i18n="card.major.value">{t("card.major.value")}</strong></div>
          <div class="meta-line"><span data-i18n="card.email.label">{t("card.email.label")}</span><strong><a href="mailto:shuangbenchen25@stu.pku.edu.cn">shuangbenchen25@stu.pku.edu.cn</a></strong></div>
          <div class="meta-line"><span data-i18n="card.research.label">{t("card.research.label")}</span><strong data-i18n="card.research.value">{t("card.research.value")}</strong></div>
          <div class="meta-line"><span>CV</span><strong><a class="text-link" href="/assets/cv/shuangben-chen-cv.pdf" data-i18n="card.cv">{t("card.cv")}</a></strong></div>
        </div>
      </aside>
    </section>
    <section class="section home-overview" aria-label="Site sections">
      <nav class="section-label guide-index-list" aria-label="Site sections">
        {homeSections.map((section) => (
          <a class="guide-index" href={`#${overviewId(section.href)}`}>
            <span class="eyebrow" data-i18n={section.kickerKey}>{t(section.kickerKey)}</span>
            <strong data-i18n={section.titleKey}>{t(section.titleKey)}</strong>
          </a>
        ))}
      </nav>
      <div class="section-guide">
        {homeSections.map((section) => (
          <article class="guide-row" id={overviewId(section.href)}>
            <div class="guide-detail">
              <div class="guide-heading">
                <h3 data-i18n={section.titleKey}>{t(section.titleKey)}</h3>
                <span data-i18n={section.descKey}>{t(section.descKey)}</span>
              </div>
              <p data-i18n={section.summaryKey}>{t(section.summaryKey)}</p>
              <div class="guide-metrics" aria-label={`${t(section.titleKey)} highlights`}>
                {section.metrics.map((metric) => (
                  <div class="guide-metric">
                    <strong>{metric.value}</strong>
                    <span data-i18n={metric.labelKey}>{t(metric.labelKey)}</span>
                  </div>
                ))}
              </div>
              <div class="guide-signals">
                {section.signals.map((signal) => (
                  <div class="guide-signal" style={`--level: ${signal.level}%`}>
                    <div>
                      <span data-i18n={signal.labelKey}>{t(signal.labelKey)}</span>
                      <strong>{signal.value}</strong>
                    </div>
                    <i aria-hidden="true"></i>
                  </div>
                ))}
              </div>
              <div class="guide-notes">
                {section.detailKeys.map((key, index) => (
                  <p class="guide-note">
                    <span>{String(index + 1).padStart(2, "0")}</span>
                    <span data-i18n={key}>{t(key)}</span>
                  </p>
                ))}
              </div>
              {recentByHref.get(section.href)?.length ? (
                <div class="guide-recents">
                  {recentByHref.get(section.href)?.map((item) => (
                    <a class="guide-recent" href={item.href}>
                      <time datetime={item.date.toISOString()}>{item.dateLabel}</time>
                      <strong>{item.title}</strong>
                      <span>{item.description || item.excerpt}</span>
                    </a>
                  ))}
                </div>
              ) : null}
              <blockquote data-i18n={section.quoteKey}>{t(section.quoteKey)}</blockquote>
              <ul class="guide-points">
                {section.pointKeys.map((key) => <li data-i18n={key}>{t(key)}</li>)}
              </ul>
              <a class="overview-more" href={section.href} data-i18n="home.more">{t("home.more")}</a>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
